# TLS-terminating reverse proxy for Axon, rendered from this template by the
# deploy*.sh scripts whenever AXON_DOMAIN (or CHAM_DOMAIN) is set in
# .deploy.env. Caddy provisions and renews the Let's Encrypt certificate for
# {$AXON_DOMAIN} automatically — no certbot cron job to maintain.
#
# {$AXON_DOMAIN} and {$AXON_PORT} are substituted by the deploy script before
# this file is copied to /etc/caddy/Caddyfile — see install_caddy() in
# run.sh (generated by deployaxongcp.sh / deploycham.sh / deploychamgcp.sh).

{$AXON_DOMAIN} {
	# Caddy reverse-proxies WebSocket upgrades by default (it just forwards the
	# Upgrade/Connection headers), but /ws is called out explicitly here since
	# it's the one route the dashboard chat UI cannot work without.
	reverse_proxy /ws localhost:{$AXON_PORT}

	reverse_proxy localhost:{$AXON_PORT}
}
