**/memory/*.db
**/memory/*.db-wal
**/memory/*.db-shm
**/data/files/
**/tools_temp/
*.sqlite
*.sqlite3

# ── Secrets ──
.env
*.env
!*.env.example
*.key
credentials.json
tokens.json

# ── Deploy bundles / archives ──
*.zip
*.tar.gz
dist/

# ── graphify output / caches ──
graphify-out/
**/graphify-out/
.graphify_*.json

# ── Logs ──
*.log

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
~$*
*.swp
.idea/
.vscode/

