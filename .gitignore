# ── Rust build artifacts ──
target/
**/target/
*.pdb

# ── Node / frontend ──
node_modules/
**/node_modules/
axon-ui/dist/

# ── Built UI copied into the agent ──
crates/axon-agent/static/assets/
crates/axon-agent/static/index.html

# ── Runtime data / databases ──
**/memory/*.db
**/memory/*.db-wal
**/memory/*.db-shm
**/data/files/
**/tools_temp/
*.sqlite
*.sqlite3

# ── Secrets ──
.env
*.env
!*.env.example
*.key
credentials.json
newcredentials.json
tokens.json

# ── Deploy bundles / archives ──
*.zip
*.tar.gz
dist/

# ── graphify output / caches ──
graphify-out/
**/graphify-out/
.graphify_*.json

# ── Claude Code personal/local settings ──
.claude/settings.local.json

# ── Logs ──
*.log

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
~$*
*.swp
.idea/
.vscode/

# Windows reserved device names that can't be indexed by git
nul
con
aux

# ── Fine-tuning tooling (finetune/) ──
finetune/.venv/
finetune/data/raw/
finetune/data/processed/
finetune/checkpoints/
finetune/merged/
finetune/gguf/*.gguf
finetune/llama.cpp/
finetune/models/

# auto-backup hook debug log (regenerated each run, not meant for history)
.claude/hooks/auto-backup.log
