<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/accent"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/serverUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/server_url_hint"
            android:inputType="textUri"
            android:textColor="@color/text"
            android:textColorHint="@color/text_dim"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/masterKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/master_key_hint"
            android:inputType="textPassword"
            android:textColor="@color/text"
            android:textColorHint="@color/text_dim"
            android:importantForAutofill="no" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save" />

            <Button
                android:id="@+id/testBtn"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/test_connection" />
        </LinearLayout>

        <TextView
            android:id="@+id/testResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_dim" />

        <!-- Server-side voice settings (tts.* / stt.*), built dynamically from
             GET /api/settings — same rows as the dashboard's Voice Input /
             Voice Replies sections. -->
        <TextView
            android:id="@+id/voiceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/text_dim" />

        <LinearLayout
            android:id="@+id/voiceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- On-device speaker verification for barge-in (see SpeakerEmbedder /
             VoicePrint) — entirely local, nothing here talks to the server. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/voice_id_title"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/voice_id_description"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/voiceIdStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_dim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/voiceIdEnrollBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_id_enroll" />

            <Button
                android:id="@+id/voiceIdClearBtn"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/voice_id_clear" />
        </LinearLayout>

        <!-- Barge-in speaker-match strictness. Adjusts the cosine-similarity
             cutoff in Prefs.bargeMatchThreshold / speakerVerifier — the fix
             for "it won't recognize my voice when I try to interrupt". -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/barge_match_title"
            android:textColor="@color/text"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/bargeMatchSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/bargeMatchValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/barge_match_description"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
