# ── Axon Agent — example environment ──────────────────────────────────────────
# Copy to `.env` and fill in real values. The agent loads this from its working
# directory (core/ in a deployment). Secrets are gitignored; this example is not.

# ── Core server ───────────────────────────────────────────────────────────────
AXON_API_KEY=changeme-dashboard-api-key

# AXON_MASTER_KEY is the dashboard's only credential AND the key every stored
# secret is encrypted under, so it must be long and random. Generate one with:
#
#     openssl rand -base64 32
#
# Boot refuses to start on a key that is under 16 characters, contains
# placeholder text (like the word "changeme"), or has almost no variety —
# see crypto::validate_master_key. Leave this blank and fill in your own.
#
# NOTE: changing this on an existing deployment makes previously stored
# credentials unreadable; they have to be re-entered in the dashboard.
AXON_MASTER_KEY=
AXON_PORT=3000
AXON_DB_PATH=memory/axon.db
RUST_LOG=info

# ── In-process integrations ───────────────────────────────────────────────────
# The integration services run inside the agent, so the OAuth/Instagram settings
# belong here (or as Instagram settings in the dashboard, which the agent maps
# onto these same vars at runtime).
#
# Public base URL Meta/Google can reach — REQUIRED for OAuth redirects and for
# publishing local media paths to Instagram. Without a public host, IG local-
# media posting fails and OAuth callbacks resolve to localhost.
#   Dashboard key: instagram.public_base_url
AXON_PUBLIC_BASE_URL=https://your-public-host.example.com
# OAuth callback host used when building auth URLs. Set to the same public host;
# either AXON_PUBLIC_BASE_URL or AXON_CALLBACK_HOST satisfies the requirement.
AXON_CALLBACK_HOST=https://your-public-host.example.com

# Temporary signed local-media URL lifetime (seconds)
#   Dashboard key: instagram.media_url_ttl_secs
AXON_MEDIA_URL_TTL_SECS=7200
# Instagram image container polling
AXON_IG_IMAGE_POLL_INTERVAL_SECS=2
AXON_IG_IMAGE_POLL_TIMEOUT_SECS=60
# Instagram video/Reels container polling
AXON_IG_VIDEO_POLL_INTERVAL_SECS=10
AXON_IG_VIDEO_POLL_TIMEOUT_SECS=600
#
# NOTE: credentials.json (your OAuth app client IDs/secrets) must sit in the
# agent's working directory (core/) or its local data directory. The deploy
# scripts ship it into core/ automatically.

# ── Messaging / vector / providers ────────────────────────────────────────────
TELOXIDE_TOKEN=your-telegram-bot-token
# Seeds the watcher.notify_chat_id DB setting on first boot only (blank = skip;
# once set — here, via the dashboard, or restored from a prior deploy's DB backup
# — this var is ignored so the DB value always wins). Sets where global error /
# scheduler notifications get sent by default.
AXON_NOTIFY_CHAT_ID=
QDRANT_URL=http://127.0.0.1:6333
VOYAGE_API_KEY=your-voyage-key

# Model provider keys are resolved DB-then-env by their exact name. Add one line
# per key; the suffix must match the model-key name configured in the dashboard,
# e.g.:
#   GEMINI_API_KEY_<NAME>=...
#   GROQ_API_KEY_<NAME>=...
#   CEREBRAS_API_KEY_<NAME>=...
#   NVIDIA_API_KEY_<NAME>=...
#   OPENROUTER_API_KEY_<NAME>=...
#   OLLAMA_API_KEY_<NAME>=...
