# Normalize line endings: repo is authored on Windows, deployed to Linux.
* text=auto eol=lf

# Shell scripts and systemd units MUST be LF (they break on the server otherwise).
*.sh    text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.yaml  text eol=lf

# Windows-only helper scripts stay CRLF.
*.bat   text eol=crlf

# Binary / non-diffable assets.
*.png   binary
*.jpg   binary
*.ico   binary
*.zip   binary
*.tar.gz binary
*.key   binary
