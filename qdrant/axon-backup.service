# =============================================================================
# /etc/systemd/system/axon-backup.service
# =============================================================================

[Unit]
Description=axon-mcp Qdrant snapshot backup
After=qdrant.service
Requires=qdrant.service

[Service]
Type=oneshot
User=ubuntu
ExecStart=/usr/local/bin/axon-backup
StandardOutput=append:/var/log/qdrant/backup.log
StandardError=append:/var/log/qdrant/backup.log
TimeoutStartSec=600
