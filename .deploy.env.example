# Deployment targets for the deploy*.sh scripts.
# Copy to .deploy.env (gitignored) and fill in your real hosts.

# axon instance (deployaxon-wipe.sh, deployaxongcp.sh)
AXON_TARGET_SERVER="user@203.0.113.10"
AXON_REMOTE_DIR="/home/user"
AXON_GCP_INSTANCE="axon"
AXON_GCP_ZONE="us-east1-c"
AXON_GCP_USER="user"

# cham instance (deploycham.sh, deploycham-wipe.sh, deploychamgcp.sh, deployfrontend.sh)
CHAM_TARGET_SERVER="user@203.0.113.20"
CHAM_REMOTE_DIR="/home/user"
CHAM_GCP_INSTANCE="cham"
CHAM_GCP_ZONE="us-central1-a"
CHAM_GCP_USER="user"
